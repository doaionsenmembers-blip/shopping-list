// =============================================
// STATE
// =============================================
let items = [];
// session[id] = { checked: bool, quantity: number, inventory: number }
let session = {};
let memo = '';
let currentStore = '全て';
let editMode = false;
let editingId = null;
let nextId = 200;

// =============================================
// STORAGE
// =============================================
function load() {
    try {
        const si = localStorage.getItem('sq_items');
        const ss = localStorage.getItem('sq_session');
        const sn = localStorage.getItem('sq_nextId');
        const sm = localStorage.getItem('sq_memo');
        items   = si ? JSON.parse(si) : DEFAULT_ITEMS.map(i => ({...i}));
        session = ss ? JSON.parse(ss) : {};
        nextId  = sn ? parseInt(sn) : (Math.max(0, ...items.map(i => i.id)) + 1);
        memo    = sm || '';
    } catch(e) {
        items = DEFAULT_ITEMS.map(i => ({...i}));
        session = {}; nextId = 200; memo = '';
    }
}

function save() {
    localStorage.setItem('sq_items',   JSON.stringify(items));
    localStorage.setItem('sq_session', JSON.stringify(session));
    localStorage.setItem('sq_nextId',  String(nextId));
    localStorage.setItem('sq_memo',    memo);
}

// =============================================
// MEMO
// =============================================
function initMemo() {
    const el = document.getElementById('memoText');
    el.value = memo;
    el.addEventListener('input', () => {
        memo = el.value;
        // auto-resize
        el.style.height = 'auto';
        el.style.height = Math.min(el.scrollHeight, 140) + 'px';
        save();
    });
    // init height
    if (memo) {
        el.style.height = 'auto';
        el.style.height = Math.min(el.scrollHeight, 140) + 'px';
    }
}

// =============================================
// RENDER
// =============================================
function render() {
    const el = document.getElementById('content');

    let filtered = currentStore === '全て'
        ? items
        : items.filter(i => i.stores.includes(currentStore));

    if (filtered.length === 0) {
        el.innerHTML = `
            <div class="empty-state">
                <div class="empty-icon">🛒</div>
                <div class="empty-title">アイテムがありません</div>
                <div class="empty-sub">「+」ボタンでアイテムを追加できます</div>
            </div>`;
        return;
    }

    const checked   = filtered.filter(i =>  session[i.id]?.checked);
    const unchecked = filtered.filter(i => !session[i.id]?.checked);

    let html = '';

    // ✅ 買い物かご（チェック済み）
    if (checked.length > 0) {
        html += `<div class="section">
            <div class="section-header">
                ✅ 買い物かご
                <span class="checked-badge">${checked.length}</span>
            </div>
            ${checked.map(renderRow).join('')}
        </div>`;
    }

    // カテゴリ別（未チェック）
    const usedCats = CATEGORIES.filter(c => unchecked.some(i => i.category === c));
    usedCats.forEach(cat => {
        const catItems = unchecked.filter(i => i.category === cat);
        if (!catItems.length) return;
        html += `<div class="section">
            <div class="section-header">${CAT_EMOJI[cat] || '📦'} ${cat}</div>
            ${catItems.map(renderRow).join('')}
        </div>`;
    });

    el.innerHTML = html;
}

function renderRow(item) {
    const s         = session[item.id] || {};
    const checked   = !!s.checked;
    const qty       = s.quantity  ?? 1;
    const inv       = s.inventory ?? 0;
    const storeLbl  = item.stores.join('・');
    const alwaysMark = item.alwaysBuy
        ? `<span class="always-star" title="毎回買う">⭐</span>`
        : '';

    const editBtns = editMode ? `
        <div class="item-edit-btns">
            <button class="btn-edit-sm" onclick="showEditModal(${item.id})" title="編集">✏️</button>
            <button class="btn-del-sm"  onclick="deleteItem(${item.id})"    title="削除">🗑️</button>
        </div>` : '';

    return `
        <div class="item-row${checked ? ' checked' : ''}" id="row-${item.id}">
            <div class="item-check${checked ? ' checked' : ''}" onclick="toggleCheck(${item.id})" role="checkbox" aria-checked="${checked}">
                ${checked ? '✓' : ''}
            </div>
            <div class="item-info">
                <div class="item-name${checked ? ' checked' : ''}">
                    ${esc(item.name)}${alwaysMark}
                </div>
                ${currentStore === '全て' ? `<div class="item-meta">${esc(storeLbl)}</div>` : ''}
            </div>

            <div class="qty-wrap">
                <!-- 買う数量 -->
                <div class="qty-controls">
                    <button class="qty-btn minus" onclick="changeQty(${item.id},-1)" aria-label="減らす">−</button>
                    <span class="qty-display" id="qty-${item.id}">${qty}${esc(item.unit)}</span>
                    <button class="qty-btn plus"  onclick="changeQty(${item.id},1)"  aria-label="増やす">+</button>
                </div>
                <!-- 在庫（内側） -->
                <div class="inv-row">
                    <span class="inv-label">在庫</span>
                    <button class="inv-btn" onclick="changeInv(${item.id},-1)" aria-label="在庫を減らす">−</button>
                    <span class="inv-display" id="inv-${item.id}">${inv}${esc(item.unit)}</span>
                    <button class="inv-btn" onclick="changeInv(${item.id},1)"  aria-label="在庫を増やす">+</button>
                </div>
            </div>

            ${editBtns}
        </div>`;
}

function esc(s) {
    return String(s)
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// =============================================
// ACTIONS
// =============================================
function setStore(store) {
    currentStore = store;
    document.querySelectorAll('.store-tab').forEach(t => {
        t.classList.toggle('active', t.dataset.store === store);
    });
    render();
}

function toggleCheck(id) {
    if (!session[id]) session[id] = { checked: false, quantity: 1, inventory: 0 };
    session[id].checked = !session[id].checked;
    save(); render();
}

function changeQty(id, delta) {
    if (!session[id]) session[id] = { checked: false, quantity: 1, inventory: 0 };
    const next = Math.max(1, (session[id].quantity ?? 1) + delta);
    session[id].quantity = next;
    save();
    const item = items.find(i => i.id === id);
    const el   = document.getElementById(`qty-${id}`);
    if (el && item) el.textContent = `${next}${item.unit}`;
}

function changeInv(id, delta) {
    if (!session[id]) session[id] = { checked: false, quantity: 1, inventory: 0 };
    const next = Math.max(0, (session[id].inventory ?? 0) + delta);
    session[id].inventory = next;
    save();
    const item = items.find(i => i.id === id);
    const el   = document.getElementById(`inv-${id}`);
    if (el && item) el.textContent = `${next}${item.unit}`;
}

function toggleEditMode() {
    editMode = !editMode;
    const btn = document.getElementById('editModeBtn');
    btn.textContent = editMode ? '完了' : '編集';
    btn.className   = editMode ? 'btn-text danger' : 'btn-text';
    render();
}

// =============================================
// ADD / EDIT MODAL
// =============================================
function showAddModal() {
    editingId = null;
    document.getElementById('modalTitle').textContent = 'アイテムを追加';
    document.getElementById('itemName').value      = '';
    document.getElementById('itemCategory').value  = 'その他';
    document.getElementById('itemUnit').value      = '個';
    document.getElementById('itemAlwaysBuy').checked = false;
    STORES.forEach(s => { document.getElementById(`chip-${s}`).checked = false; });
    document.getElementById('chip-スーパー').checked = true;
    showModal('itemModal');
    setTimeout(() => document.getElementById('itemName').focus(), 300);
}

function showEditModal(id) {
    const item = items.find(i => i.id === id);
    if (!item) return;
    editingId = id;
    document.getElementById('modalTitle').textContent = 'アイテムを編集';
    document.getElementById('itemName').value       = item.name;
    document.getElementById('itemCategory').value   = item.category;
    document.getElementById('itemUnit').value       = item.unit;
    document.getElementById('itemAlwaysBuy').checked = !!item.alwaysBuy;
    STORES.forEach(s => { document.getElementById(`chip-${s}`).checked = item.stores.includes(s); });
    showModal('itemModal');
}

function saveItem() {
    const name = document.getElementById('itemName').value.trim();
    if (!name) { toast('名前を入力してください'); return; }
    const category  = document.getElementById('itemCategory').value;
    const unit      = document.getElementById('itemUnit').value.trim() || '個';
    const stores    = STORES.filter(s => document.getElementById(`chip-${s}`).checked);
    const alwaysBuy = document.getElementById('itemAlwaysBuy').checked;
    if (!stores.length) { toast('買う場所を選んでください'); return; }

    if (editingId != null) {
        const idx = items.findIndex(i => i.id === editingId);
        if (idx >= 0) items[idx] = { ...items[idx], name, category, unit, stores, alwaysBuy };
        toast('更新しました');
    } else {
        items.push({ id: nextId++, name, category, unit, stores, alwaysBuy });
        toast('追加しました');
    }
    save(); hideModal('itemModal'); render();
}

function deleteItem(id) {
    if (!confirm('このアイテムを削除しますか？')) return;
    items = items.filter(i => i.id !== id);
    delete session[id];
    save(); render();
    toast('削除しました');
}

// =============================================
// SHARE
// =============================================
function showShareModal() {
    document.getElementById('importArea').style.display = 'none';
    document.getElementById('importText').value = '';
    showModal('shareModal');
}

function exportData() {
    const data = JSON.stringify({ items, nextId });
    if (navigator.clipboard) {
        navigator.clipboard.writeText(data)
            .then(() => toast('コピーしました！他のデバイスに貼り付けてください'))
            .catch(() => fallbackCopy(data));
    } else { fallbackCopy(data); }
}

function fallbackCopy(text) {
    const ta = document.createElement('textarea');
    ta.value = text; ta.style.position = 'fixed'; ta.style.opacity = '0';
    document.body.appendChild(ta); ta.focus(); ta.select();
    document.execCommand('copy'); document.body.removeChild(ta);
    toast('コピーしました！');
}

function toggleImportArea() {
    const a = document.getElementById('importArea');
    a.style.display = a.style.display === 'none' ? 'block' : 'none';
}

function importData() {
    const text = document.getElementById('importText').value.trim();
    try {
        const data = JSON.parse(text);
        if (!data.items || !Array.isArray(data.items)) throw new Error();
        if (!confirm(`${data.items.length}件のアイテムをインポートします。現在のマスターリストは上書きされます。よろしいですか？`)) return;
        items = data.items;
        if (data.nextId) nextId = data.nextId;
        save(); render(); hideModal('shareModal');
        toast('インポートしました！');
    } catch(e) { toast('データの形式が正しくありません'); }
}

// =============================================
// RESET（毎回買う → 自動チェック）
// =============================================
function confirmResetSession() {
    const alwaysCount = items.filter(i => i.alwaysBuy).length;
    const msg = alwaysCount > 0
        ? `チェック・数量をリセットし、⭐毎回買う設定の${alwaysCount}件を自動チェックします。よろしいですか？`
        : 'チェック・数量をすべてリセットしますか？\n（マスターリストは変わりません）';
    if (!confirm(msg)) return;

    // 在庫は引き継ぐ
    const prevInv = {};
    Object.keys(session).forEach(id => {
        if (session[id].inventory) prevInv[id] = session[id].inventory;
    });

    session = {};

    // 在庫を復元
    Object.keys(prevInv).forEach(id => {
        if (!session[id]) session[id] = { checked: false, quantity: 1, inventory: 0 };
        session[id].inventory = prevInv[id];
    });

    // 毎回買うアイテムを自動チェック
    items.forEach(item => {
        if (item.alwaysBuy) {
            if (!session[item.id]) session[item.id] = { checked: false, quantity: 1, inventory: 0 };
            session[item.id].checked  = true;
            session[item.id].quantity = session[item.id].quantity || 1;
        }
    });

    save(); render(); hideModal('shareModal');
    toast(`リセット完了${alwaysCount > 0 ? `・${alwaysCount}件を自動チェック✅` : ''}`);
}

// =============================================
// MODAL HELPERS
// =============================================
function showModal(id)  { document.getElementById(id).classList.add('show'); }
function hideModal(id)  { document.getElementById(id).classList.remove('show'); }
function overlayClose(e, id) { if (e.target === e.currentTarget) hideModal(id); }

// =============================================
// TOAST
// =============================================
let _toastTimer;
function toast(msg) {
    const el = document.getElementById('toast');
    el.textContent = msg; el.classList.add('show');
    clearTimeout(_toastTimer);
    _toastTimer = setTimeout(() => el.classList.remove('show'), 2500);
}

// =============================================
// KEYBOARD
// =============================================
document.getElementById('itemName').addEventListener('keydown', e => {
    if (e.key === 'Enter') saveItem();
});

// =============================================
// INIT
// =============================================
load();
initMemo();
render();
</script>
