<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="apple-mobile-web-app-title" content="お買い物">
    <title>お買い物リスト</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
        :root {
            --primary: #007AFF;
            --success: #34C759;
            --danger: #FF3B30;
            --orange: #FF9500;
            --bg: #F2F2F7;
            --card: #FFFFFF;
            --text: #000000;
            --text-sub: #6C6C70;
            --sep: #C6C6C8;
            --checked-bg: #F0FFF4;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Yu Gothic', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            padding-bottom: 90px;
        }

        /* ---- HEADER ---- */
        .header {
            background: var(--card);
            padding: 14px 16px 0;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 1px 0 var(--sep);
        }
        .header-top {
            display: flex; align-items: center;
            justify-content: space-between;
            margin-bottom: 12px;
        }
        .header-title { font-size: 22px; font-weight: 800; letter-spacing: -0.5px; }
        .header-actions { display: flex; gap: 6px; }
        .btn-text {
            background: none; border: none;
            font-size: 15px; font-weight: 600;
            color: var(--primary); padding: 5px 10px;
            border-radius: 8px; cursor: pointer;
        }
        .btn-text.danger { color: var(--danger); }

        /* Store tabs */
        .store-tabs {
            display: flex; gap: 6px;
            overflow-x: auto; padding-bottom: 12px;
            scrollbar-width: none;
        }
        .store-tabs::-webkit-scrollbar { display: none; }
        .store-tab {
            white-space: nowrap;
            padding: 7px 16px;
            border-radius: 20px; border: none;
            background: var(--bg); color: var(--text-sub);
            font-size: 14px; font-weight: 600;
            cursor: pointer; transition: all 0.15s;
            flex-shrink: 0;
        }
        .store-tab.active { background: var(--primary); color: #fff; }

        /* ---- MEMO ---- */
        .memo-wrap {
            margin: 12px 16px 0;
        }
        .memo-textarea {
            width: 100%;
            min-height: 52px;
            max-height: 140px;
            padding: 11px 14px;
            border: 1.5px solid var(--sep);
            border-radius: 14px;
            font-size: 15px;
            font-family: inherit;
            background: var(--card);
            color: var(--text);
            outline: none;
            resize: none;
            line-height: 1.5;
            transition: border-color 0.15s, box-shadow 0.15s;
            box-shadow: 0 1px 3px rgba(0,0,0,.05);
            overflow-y: auto;
        }
        .memo-textarea:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(0,122,255,.12);
        }
        .memo-textarea::placeholder { color: #AEAEB2; }

        /* ---- CONTENT ---- */
        .content { padding: 12px 16px; }

        /* ---- SECTION ---- */
        .section {
            background: var(--card);
            border-radius: 14px;
            margin-bottom: 12px;
            overflow: hidden;
            box-shadow: 0 1px 3px rgba(0,0,0,.06);
        }
        .section-header {
            padding: 9px 16px;
            font-size: 12px; font-weight: 700;
            color: var(--text-sub);
            text-transform: uppercase;
            letter-spacing: 0.6px;
            background: #FAFAFA;
            border-bottom: 1px solid var(--sep);
            display: flex; align-items: center; gap: 6px;
        }
        .checked-badge {
            background: var(--success); color: #fff;
            font-size: 11px; font-weight: 700;
            padding: 1px 7px; border-radius: 10px;
        }

        /* ---- ITEM ROW ---- */
        .item-row {
            display: flex; align-items: center;
            padding: 10px 14px;
            border-bottom: 1px solid var(--sep);
            gap: 10px;
            transition: background 0.15s;
            min-height: 60px;
        }
        .item-row:last-child { border-bottom: none; }
        .item-row.checked { background: var(--checked-bg); }

        /* Checkbox circle */
        .item-check {
            width: 26px; height: 26px;
            border-radius: 50%;
            border: 2px solid var(--sep);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer; flex-shrink: 0;
            transition: all 0.15s;
            font-size: 14px; color: transparent;
        }
        .item-check.checked {
            background: var(--success);
            border-color: var(--success);
            color: #fff;
        }

        /* Item info */
        .item-info { flex: 1; min-width: 0; }
        .item-name {
            font-size: 16px; font-weight: 500;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
            display: flex; align-items: center; gap: 5px;
        }
        .item-name.checked { text-decoration: line-through; color: var(--text-sub); }
        .item-meta { font-size: 12px; color: var(--text-sub); margin-top: 1px; }
        .always-star {
            font-size: 11px; color: var(--orange);
            flex-shrink: 0;
        }

        /* ---- QTY WRAP (buy + inventory stacked) ---- */
        .qty-wrap {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            flex-shrink: 0;
        }

        /* Buy quantity row */
        .qty-controls { display: flex; align-items: center; gap: 4px; }
        .qty-btn {
            width: 30px; height: 30px;
            border-radius: 50%; border: none;
            font-size: 20px; font-weight: 400;
            cursor: pointer; display: flex;
            align-items: center; justify-content: center;
            line-height: 1; flex-shrink: 0;
            transition: transform 0.1s;
        }
        .qty-btn:active { transform: scale(0.9); }
        .qty-btn.plus  { background: var(--primary); color: #fff; }
        .qty-btn.minus { background: #E5E5EA; color: var(--text-sub); }
        .qty-display {
            font-size: 14px; font-weight: 700;
            min-width: 44px; text-align: center;
            color: var(--text);
        }

        /* Inventory row (nested inside qty-wrap) */
        .inv-row {
            display: flex; align-items: center; gap: 3px;
            background: #EFEFF4;
            border-radius: 10px;
            padding: 3px 7px;
        }
        .inv-label {
            font-size: 10px; font-weight: 700;
            color: var(--text-sub); letter-spacing: 0.3px;
            margin-right: 2px;
        }
        .inv-btn {
            width: 20px; height: 20px;
            border-radius: 50%; border: 1px solid #C6C6C8;
            background: var(--card);
            font-size: 15px; font-weight: 400;
            cursor: pointer; display: flex;
            align-items: center; justify-content: center;
            line-height: 1; flex-shrink: 0;
            color: var(--text-sub);
            transition: transform 0.1s;
        }
        .inv-btn:active { transform: scale(0.88); }
        .inv-display {
            font-size: 13px; font-weight: 700;
            min-width: 30px; text-align: center;
            color: var(--text);
        }

        /* Edit action buttons */
        .item-edit-btns { display: flex; gap: 6px; flex-shrink: 0; }
        .btn-edit-sm, .btn-del-sm {
            width: 32px; height: 32px;
            border-radius: 8px; border: none;
            cursor: pointer; font-size: 15px;
            display: flex; align-items: center; justify-content: center;
        }
        .btn-edit-sm { background: #E3F0FF; }
        .btn-del-sm  { background: #FFECEC; }

        /* ---- FAB ---- */
        .fab {
            position: fixed; bottom: 28px; right: 20px;
            width: 58px; height: 58px;
            border-radius: 50%; background: var(--primary);
            color: #fff; border: none;
            font-size: 30px; cursor: pointer;
            box-shadow: 0 4px 18px rgba(0,122,255,.45);
            display: flex; align-items: center; justify-content: center;
            z-index: 200; transition: transform 0.15s;
        }
        .fab:active { transform: scale(0.93); }

        /* ---- MODAL ---- */
        .modal-overlay {
            position: fixed; inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 1000;
            display: none; align-items: flex-end; justify-content: center;
        }
        .modal-overlay.show { display: flex; }
        .modal {
            background: var(--card);
            border-radius: 22px 22px 0 0;
            width: 100%; max-height: 92vh;
            overflow-y: auto;
            padding: 20px 20px 44px;
            animation: slideUp 0.25s ease;
        }
        @keyframes slideUp {
            from { transform: translateY(60px); opacity: 0; }
            to   { transform: translateY(0);    opacity: 1; }
        }
        .modal-handle {
            width: 40px; height: 4px;
            background: var(--sep); border-radius: 2px;
            margin: 0 auto 16px;
        }
        .modal-header {
            display: flex; align-items: center;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .modal-title { font-size: 19px; font-weight: 700; }
        .modal-close {
            background: var(--bg); border: none;
            width: 30px; height: 30px;
            border-radius: 50%; font-size: 16px;
            cursor: pointer; color: var(--text-sub);
            display: flex; align-items: center; justify-content: center;
        }

        /* Form */
        .form-group { margin-bottom: 18px; }
        .form-label {
            display: block; font-size: 13px; font-weight: 700;
            color: var(--text-sub); margin-bottom: 7px;
            text-transform: uppercase; letter-spacing: 0.5px;
        }
        .form-input, .form-select {
            width: 100%; padding: 13px 14px;
            border: 1.5px solid var(--sep);
            border-radius: 12px; font-size: 16px;
            font-family: inherit; background: var(--bg);
            color: var(--text); outline: none;
            transition: border-color 0.15s;
            appearance: none; -webkit-appearance: none;
        }
        .form-input:focus, .form-select:focus {
            border-color: var(--primary); background: #fff;
        }
        .select-wrap { position: relative; }
        .select-wrap::after {
            content: '▾'; position: absolute;
            right: 14px; top: 50%;
            transform: translateY(-50%);
            color: var(--text-sub); pointer-events: none;
        }
        .store-chips { display: flex; flex-wrap: wrap; gap: 8px; }
        .store-chip-input { display: none; }
        .store-chip-label {
            padding: 8px 16px; border-radius: 20px;
            border: 1.5px solid var(--sep);
            font-size: 14px; font-weight: 500;
            cursor: pointer; transition: all 0.15s;
            user-select: none;
        }
        .store-chip-input:checked + .store-chip-label {
            background: var(--primary); color: #fff; border-color: var(--primary);
        }

        /* Toggle switch (毎回買う) */
        .toggle-row {
            display: flex; align-items: center;
            justify-content: space-between;
            background: var(--bg);
            border-radius: 12px;
            padding: 13px 16px;
            cursor: pointer;
        }
        .toggle-row-left {
            display: flex; align-items: center; gap: 8px;
        }
        .toggle-row-icon { font-size: 20px; }
        .toggle-row-text { font-size: 15px; font-weight: 600; }
        .toggle-row-sub  { font-size: 12px; color: var(--text-sub); margin-top: 1px; }
        .toggle-input { display: none; }
        .toggle-switch {
            width: 51px; height: 31px;
            border-radius: 16px;
            background: #E5E5EA;
            position: relative; flex-shrink: 0;
            transition: background 0.2s;
        }
        .toggle-switch::after {
            content: '';
            position: absolute;
            top: 3px; left: 3px;
            width: 25px; height: 25px;
            border-radius: 50%;
            background: #fff;
            box-shadow: 0 2px 6px rgba(0,0,0,.25);
            transition: transform 0.2s;
        }
        .toggle-input:checked ~ .toggle-switch {
            background: var(--orange);
        }
        .toggle-input:checked ~ .toggle-switch::after {
            transform: translateX(20px);
        }

        .btn-primary {
            width: 100%; padding: 15px;
            background: var(--primary); color: #fff;
            border: none; border-radius: 14px;
            font-size: 17px; font-weight: 700;
            cursor: pointer; margin-top: 4px;
            transition: opacity 0.15s;
        }
        .btn-primary:active { opacity: 0.85; }
        .btn-secondary {
            width: 100%; padding: 13px;
            background: var(--bg); color: var(--primary);
            border: 1.5px solid var(--primary);
            border-radius: 14px; font-size: 16px; font-weight: 600;
            cursor: pointer; margin-bottom: 10px;
        }
        .btn-danger-outline {
            width: 100%; padding: 13px;
            background: var(--bg); color: var(--danger);
            border: 1.5px solid var(--danger);
            border-radius: 14px; font-size: 16px; font-weight: 600;
            cursor: pointer;
        }

        /* Empty state */
        .empty-state { text-align: center; padding: 50px 20px; color: var(--text-sub); }
        .empty-icon  { font-size: 52px; margin-bottom: 12px; }
        .empty-title { font-size: 18px; font-weight: 600; margin-bottom: 6px; }
        .empty-sub   { font-size: 14px; }

        /* Toast */
        .toast {
            position: fixed; bottom: 110px; left: 50%;
            transform: translateX(-50%) translateY(10px);
            background: rgba(30,30,30,.9); color: #fff;
            padding: 10px 22px; border-radius: 22px;
            font-size: 14px; font-weight: 500;
            z-index: 3000; opacity: 0;
            transition: opacity 0.2s, transform 0.2s;
            white-space: nowrap; pointer-events: none;
        }
        .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

        .modal-divider { border: none; border-top: 1px solid var(--sep); margin: 18px 0; }
        .info-text { font-size: 14px; color: var(--text-sub); line-height: 1.6; margin-bottom: 14px; }
        .form-textarea {
            width: 100%; padding: 12px 14px;
            border: 1.5px solid var(--sep); border-radius: 12px;
            font-size: 13px; font-family: monospace;
            background: var(--bg); color: var(--text);
            outline: none; resize: none; min-height: 100px;
        }
        .form-textarea:focus { border-color: var(--primary); background: #fff; }
    </style>
</head>
<body>

<!-- Header -->
<div class="header">
    <div class="header-top">
        <div class="header-title">🛒 お買い物リスト</div>
        <div class="header-actions">
            <button class="btn-text" id="editModeBtn" onclick="toggleEditMode()">編集</button>
            <button class="btn-text" onclick="showShareModal()">共有</button>
        </div>
    </div>
    <div class="store-tabs">
        <button class="store-tab active" data-store="全て"        onclick="setStore('全て')">全て</button>
        <button class="store-tab"        data-store="スーパー"    onclick="setStore('スーパー')">スーパー</button>
        <button class="store-tab"        data-store="ドラッグストア" onclick="setStore('ドラッグストア')">ドラッグストア</button>
        <button class="store-tab"        data-store="アミカ"      onclick="setStore('アミカ')">アミカ</button>
        <button class="store-tab"        data-store="その他"      onclick="setStore('その他')">その他</button>
    </div>
</div>

<!-- Memo -->
<div class="memo-wrap">
    <textarea class="memo-textarea" id="memoText" placeholder="📝 メモ（特記事項・買い忘れなど）..."></textarea>
</div>

<!-- Main content -->
<div class="content" id="content"></div>

<!-- FAB -->
<button class="fab" onclick="showAddModal()" title="アイテムを追加">+</button>

<!-- ======= Add / Edit Item Modal ======= -->
<div class="modal-overlay" id="itemModal" onclick="overlayClose(event,'itemModal')">
    <div class="modal">
        <div class="modal-handle"></div>
        <div class="modal-header">
            <div class="modal-title" id="modalTitle">アイテムを追加</div>
            <button class="modal-close" onclick="hideModal('itemModal')">✕</button>
        </div>

        <div class="form-group">
            <label class="form-label">名前 *</label>
            <input type="text" class="form-input" id="itemName" placeholder="例：牛乳" autocomplete="off">
        </div>

        <div class="form-group">
            <label class="form-label">カテゴリー</label>
            <div class="select-wrap">
                <select class="form-select" id="itemCategory">
                    <option value="野菜・果物">🥦 野菜・果物</option>
                    <option value="肉・魚">🥩 肉・魚</option>
                    <option value="乳製品・卵">🥛 乳製品・卵</option>
                    <option value="飲み物">🧃 飲み物</option>
                    <option value="冷凍食品">🧊 冷凍食品</option>
                    <option value="お菓子">🍫 お菓子</option>
                    <option value="調味料・乾物">🧂 調味料・乾物</option>
                    <option value="日用品">🧴 日用品</option>
                    <option value="薬・健康">💊 薬・健康</option>
                    <option value="その他">📦 その他</option>
                </select>
            </div>
        </div>

        <div class="form-group">
            <label class="form-label">単位（例：個・本・袋）</label>
            <input type="text" class="form-input" id="itemUnit" placeholder="個" autocomplete="off">
        </div>

        <div class="form-group">
            <label class="form-label">買う場所 *</label>
            <div class="store-chips">
                <input type="checkbox" class="store-chip-input" id="chip-スーパー"    value="スーパー">
                <label class="store-chip-label" for="chip-スーパー">スーパー</label>

                <input type="checkbox" class="store-chip-input" id="chip-ドラッグストア" value="ドラッグストア">
                <label class="store-chip-label" for="chip-ドラッグストア">ドラッグストア</label>

                <input type="checkbox" class="store-chip-input" id="chip-アミカ" value="アミカ">
                <label class="store-chip-label" for="chip-アミカ">アミカ</label>

                <input type="checkbox" class="store-chip-input" id="chip-その他" value="その他">
                <label class="store-chip-label" for="chip-その他">その他</label>
            </div>
        </div>

        <!-- 毎回買う トグル -->
        <div class="form-group">
            <label class="toggle-row" for="itemAlwaysBuy">
                <div class="toggle-row-left">
                    <span class="toggle-row-icon">⭐</span>
                    <div>
                        <div class="toggle-row-text">毎回買う</div>
                        <div class="toggle-row-sub">リセット時に自動でチェックが入ります</div>
                    </div>
                </div>
                <input type="checkbox" class="toggle-input" id="itemAlwaysBuy">
                <span class="toggle-switch"></span>
            </label>
        </div>

        <button class="btn-primary" onclick="saveItem()">保存する</button>
    </div>
</div>

<!-- ======= Share / Sync Modal ======= -->
<div class="modal-overlay" id="shareModal" onclick="overlayClose(event,'shareModal')">
    <div class="modal">
        <div class="modal-handle"></div>
        <div class="modal-header">
            <div class="modal-title">共有・同期</div>
            <button class="modal-close" onclick="hideModal('shareModal')">✕</button>
        </div>

        <p class="info-text">マスターリストをJSON形式でエクスポートし、他のデバイスでインポートすることで共有できます。</p>

        <button class="btn-primary" onclick="exportData()" style="margin-bottom:10px;">
            📤 マスターリストをコピー
        </button>
        <button class="btn-secondary" onclick="toggleImportArea()">
            📥 データをインポート
        </button>

        <div id="importArea" style="display:none;margin-top:4px;">
            <label class="form-label" style="margin-bottom:6px;">コピーしたデータを貼り付け</label>
            <textarea class="form-textarea" id="importText" placeholder="ここに貼り付けてください..."></textarea>
            <button class="btn-primary" onclick="importData()" style="margin-top:8px;">インポートする</button>
        </div>

        <hr class="modal-divider">

        <button class="btn-danger-outline" onclick="confirmResetSession()">
            🔄 今回の買い物をリセット
        </button>
        <p style="font-size:12px;color:var(--text-sub);margin-top:8px;text-align:center;">
            ⭐ 毎回買う設定のアイテムは自動でチェックが入ります
        </p>
    </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
